#!/usr/bin/env python3
"""Evaluate deterministic wiki retrieval against labeled query cases."""
import argparse
import json
from pathlib import Path
import subprocess
import sys


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--root", required=True)
    parser.add_argument("--cases", required=True)
    parser.add_argument("--k", type=int, default=5)
    parser.add_argument("--min-recall", type=float)
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()
    if args.k < 1:
        parser.error("--k must be positive")
    if args.min_recall is not None and not 0 <= args.min_recall <= 1:
        parser.error("--min-recall must be between 0 and 1")
    try:
        cases = json.loads(Path(args.cases).read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        parser.error(str(exc))
    if not isinstance(cases, list) or not cases:
        parser.error("cases must be a non-empty JSON array")

    query_tool = Path(__file__).resolve().with_name("wiki-query")
    results = []
    for number, case in enumerate(cases, 1):
        if not isinstance(case, dict) or not isinstance(case.get("query"), str):
            parser.error(f"case {number} requires a string query")
        expected = case.get("expected", [])
        if not isinstance(expected, list) or not expected or not all(isinstance(x, str) for x in expected):
            parser.error(f"case {number} requires a non-empty expected path list")
        if not all(isinstance(x, str) for x in case.get("types", [])):
            parser.error(f"case {number} types must be a string list")
        if not all(isinstance(x, str) for x in case.get("tags", [])):
            parser.error(f"case {number} tags must be a string list")
        command = [str(query_tool), "--root", args.root, "--limit", str(args.k)]
        for value in case.get("types", []):
            command.extend(("--type", value))
        for value in case.get("tags", []):
            command.extend(("--tag", value))
        command.extend(case["query"].split())
        completed = subprocess.run(command, capture_output=True, text=True)
        if completed.returncode:
            print(completed.stderr, file=sys.stderr)
            return 2
        ranked = [line.split(maxsplit=2)[1] for line in completed.stdout.splitlines() if len(line.split()) >= 2]
        rank = next((index + 1 for index, path in enumerate(ranked) if path in expected), None)
        results.append({
            "id": case.get("id", str(number)),
            "query": case["query"],
            "rank": rank,
            "hit": rank is not None,
            "top_k": ranked,
        })

    recall = sum(item["hit"] for item in results) / len(results)
    mrr = sum((1 / item["rank"]) if item["rank"] else 0 for item in results) / len(results)
    report = {"cases": len(results), "k": args.k, "recall_at_k": recall, "mrr": mrr, "results": results}
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print(f"cases={len(results)} recall@{args.k}={recall:.3f} mrr={mrr:.3f}")
        for item in results:
            if not item["hit"]:
                print(f"  MISS {item['id']}: {item['query']}")
    if args.min_recall is not None and recall < args.min_recall:
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
