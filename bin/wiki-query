#!/usr/bin/env python3
"""wiki-query — deterministic lexical search over the wiki. No model, no network.

Same input always yields the same ranked output (BM25 over title/body/tags/aliases, with a
stable path tie-break). This is the middle rung of the Query operation: the agent reads the
index first, then runs `wiki-query` to locate specific pages, then link-walks and cites.

Usage:
    wiki-query [--root DIR] [--type T]... [--tag T]... [--neighbors] [--limit N] QUERY...
    wiki-query --catalog [--root DIR]        # (re)build catalog.tsv and exit

Root resolution: --root, else $CLAUDE_PLUGIN_OPTION_WIKI_ROOT, else $WIKI_ROOT, else ~/wiki.
catalog.tsv (path, type, title, tags, aliases, timestamp, description) is regenerated on every
run so it never goes stale; --catalog just writes it without searching.
"""
import argparse
import math
import os
import re
import subprocess
import sys


def resolve_root(cli):
    if cli:
        return os.path.expanduser(cli)
    env = os.environ.get("CLAUDE_PLUGIN_OPTION_WIKI_ROOT") or os.environ.get("WIKI_ROOT")
    return os.path.expanduser(env) if env else os.path.expanduser("~/wiki")


def git_files(kb):
    out = subprocess.run(["git", "ls-files", "*.md"], cwd=kb,
                         capture_output=True, text=True).stdout
    return [f for f in out.splitlines() if f and not f.startswith("sources/")]


def frontmatter(text):
    m = re.match(r"^---\n(.*?)\n---\n?(.*)$", text, re.S)
    if not m:
        return {}, text
    fm, body = {}, m.group(2)
    for line in m.group(1).split("\n"):
        km = re.match(r"^(\w[\w-]*):\s*(.*)$", line)
        if km:
            fm[km.group(1)] = km.group(2).strip()
    return fm, body


def listish(val):
    if not val:
        return []
    val = val.strip().strip("[]")
    return [x.strip().strip("\"'") for x in val.split(",") if x.strip()]


TOKEN = re.compile(r"[a-z0-9]+")


def tokenize(s):
    return TOKEN.findall(s.lower())


def build_index(kb):
    """Return docs: list of {path,type,title,tags,aliases,timestamp,description,tokens,links}."""
    docs = []
    for f in git_files(kb):
        try:
            text = open(os.path.join(kb, f), encoding="utf-8").read()
        except OSError:
            continue
        fm, body = frontmatter(text)
        title = fm.get("title", os.path.basename(f)[:-3])
        tags = listish(fm.get("tags"))
        aliases = listish(fm.get("aliases"))
        desc = fm.get("description", "")
        # title/tags/aliases weighted by repetition into the token bag
        toks = tokenize(title) * 3 + tokenize(" ".join(tags)) * 2 \
            + tokenize(" ".join(aliases)) * 2 + tokenize(desc) * 2 + tokenize(body)
        links = set()
        d = os.path.dirname(f)
        for t in re.findall(r"\]\(([^)#\s]+)", text):
            if t.startswith(("http", "mailto", "tel", "ftp")):
                continue
            tgt = t.lstrip("/") if t.startswith("/") else os.path.normpath(os.path.join(d, t))
            links.add(tgt)
        docs.append({
            "path": f, "type": fm.get("type", ""), "title": title, "tags": tags,
            "aliases": aliases, "timestamp": fm.get("timestamp", ""),
            "description": desc, "tokens": toks, "links": links,
        })
    return docs


def write_catalog(kb, docs):
    path = os.path.join(kb, "catalog.tsv")
    with open(path, "w", encoding="utf-8") as fh:
        fh.write("path\ttype\ttitle\ttags\taliases\ttimestamp\tdescription\n")
        for d in sorted(docs, key=lambda x: x["path"]):
            fh.write("\t".join([
                d["path"], d["type"], d["title"], ",".join(d["tags"]),
                ",".join(d["aliases"]), d["timestamp"],
                d["description"].replace("\t", " "),
            ]) + "\n")
    return path


def bm25(docs, query_tokens, k1=1.5, b=0.75):
    import collections
    N = len(docs)
    if not N:
        return []
    dfreq = collections.Counter()
    tfs = []
    for d in docs:
        tf = collections.Counter(d["tokens"])
        tfs.append(tf)
        for term in set(tf):
            dfreq[term] += 1
    avg_len = sum(len(d["tokens"]) for d in docs) / N
    scores = []
    for i, d in enumerate(docs):
        tf = tfs[i]
        dl = len(d["tokens"]) or 1
        score = 0.0
        for term in query_tokens:
            if term not in tf:
                continue
            idf = math.log(1 + (N - dfreq[term] + 0.5) / (dfreq[term] + 0.5))
            freq = tf[term]
            score += idf * (freq * (k1 + 1)) / (freq + k1 * (1 - b + b * dl / avg_len))
        # alias exact-phrase boost
        q = " ".join(query_tokens)
        if any(q == a.lower() for a in d["aliases"]) or q == d["title"].lower():
            score += 5.0
        scores.append((score, d["path"], d))
    scores.sort(key=lambda x: (-x[0], x[1]))
    return [(s, d) for s, _, d in scores if s > 0]


def main():
    ap = argparse.ArgumentParser(add_help=True)
    ap.add_argument("query", nargs="*")
    ap.add_argument("--root")
    ap.add_argument("--type", action="append", default=[])
    ap.add_argument("--tag", action="append", default=[])
    ap.add_argument("--neighbors", action="store_true")
    ap.add_argument("--limit", type=int, default=10)
    ap.add_argument("--catalog", action="store_true")
    a = ap.parse_args()

    kb = resolve_root(a.root)
    if not os.path.isdir(kb):
        print(f"wiki-query: wiki root not found: {kb}", file=sys.stderr)
        return 2
    docs = build_index(kb)
    cat = write_catalog(kb, docs)

    if a.catalog:
        print(f"wrote {cat} ({len(docs)} pages)")
        return 0
    if not a.query:
        print("wiki-query: no query terms (use --catalog to just rebuild the catalog)", file=sys.stderr)
        return 2

    pool = docs
    if a.type:
        want = {t.lower() for t in a.type}
        pool = [d for d in pool if d["type"].lower() in want]
    if a.tag:
        want = {t.lower() for t in a.tag}
        pool = [d for d in pool if want & {x.lower() for x in d["tags"]}]

    ranked = bm25(pool, tokenize(" ".join(a.query)))
    top = ranked[:a.limit]

    if a.neighbors and top:
        by_path = {d["path"]: d for d in docs}
        seen = {d["path"] for _, d in top}
        extra = []
        for _, d in top:
            for lk in d["links"]:
                if lk in by_path and lk not in seen:
                    seen.add(lk)
                    extra.append((0.0, by_path[lk]))
        top += extra

    if not top:
        print("(no matches)")
        return 0
    for score, d in top:
        tag = f" [{d['type']}]" if d["type"] else ""
        mark = "  ~neighbor" if score == 0.0 and a.neighbors else ""
        print(f"{score:6.2f}  {d['path']}{tag}  {d['title']}{mark}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
