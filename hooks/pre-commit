#!/usr/bin/env bash
# git pre-commit gate for the wiki: run the deterministic lint. Blocks the commit only on broken
# links or unresolved commit-gate tokens; advisory warnings (orphans, no-type, stale) pass.
# This is the wiki's OWN copy (installed by wiki-setup into <wiki>/hooks/), so a bare clone lints
# without the plugin present. Bypass once with: git commit --no-verify
exec "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lint.sh"
